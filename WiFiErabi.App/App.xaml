<Application x:Class="WiFiErabi.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WiFiErabi.App"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <FontFamily x:Key="AppFontFamily">/Fonts/#UDEV Gothic JPDOC, BIZ UDPGothic, Segoe UI</FontFamily>

        <Style TargetType="{x:Type Window}">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        </Style>

        <Style TargetType="{x:Type Control}">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        </Style>

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        </Style>
    </Application.Resources>
</Application>
