<Window x:Class="WiFiErabi.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Wi-Fiえらび"
        Width="920"
        Height="560"
        MinWidth="820"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="#F6F7FB">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,10"
                Padding="16"
                Background="White"
                CornerRadius="12">
            <StackPanel>
                <TextBlock Text="Wi-Fiえらび"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#1F2937" />
                <TextBlock x:Name="SubtitleTextBlock"
                           Margin="0,6,0,0"
                           Foreground="#4B5563"
                           Text="おすすめ順に並んでいます。行を選んで [接続] を押してください。" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Padding="10"
                Background="White"
                CornerRadius="12">
            <DataGrid x:Name="WifiDataGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      CanUserResizeColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeaderWidth="0"
                      HorizontalScrollBarVisibility="Disabled"
                      MouseDoubleClick="WifiDataGrid_MouseDoubleClick"
                      SelectionChanged="WifiDataGrid_SelectionChanged">
                <DataGrid.Resources>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White" />
                        <Setter Property="Foreground" Value="#111827" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Current}" Value="True">
                                <Setter Property="Background" Value="#FDE7F3" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="現在" Binding="{Binding CurrentMark}" Width="44" />
                    <DataGridTextColumn Header="評価" Binding="{Binding Rank}" Width="56" />
                    <DataGridTextColumn Header="Wi-Fi 名" Binding="{Binding SSID}" Width="2*" />
                    <DataGridTextColumn Header="電波" Binding="{Binding SignalBar}" Width="1.2*" />
                    <DataGridTextColumn Header="強度" Binding="{Binding Signal}" Width="56" />
                    <DataGridTextColumn Header="Ch" Binding="{Binding Channel}" Width="48" />
                    <DataGridTextColumn Header="帯域" Binding="{Binding Band}" Width="68" />
                    <DataGridTextColumn Header="規格" Binding="{Binding RadioType}" Width="82" />
                    <DataGridTextColumn Header="使用数" Binding="{Binding ChannelUse}" Width="56" />
                    <DataGridTextColumn Header="混雑度" Binding="{Binding Congestion}" Width="82" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusTextBlock"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Foreground="#4B5563"
                       Text="現在の接続先には * が付きます。" />

            <Button x:Name="RefreshButton"
                    Grid.Column="1"
                    Width="96"
                    Height="34"
                    Margin="8,0,0,0"
                    Click="RefreshButton_Click"
                    Content="再読込" />

            <Button x:Name="ConnectButton"
                    Grid.Column="2"
                    Width="112"
                    Height="34"
                    Margin="8,0,0,0"
                    Click="ConnectButton_Click"
                    Content="接続"
                    IsEnabled="False" />

            <Button x:Name="CloseButton"
                    Grid.Column="3"
                    Width="112"
                    Height="34"
                    Margin="8,0,0,0"
                    Click="CloseButton_Click"
                    Content="閉じる"
                    IsCancel="True" />
        </Grid>
    </Grid>
</Window>
